# ── ENSO Forecast pipeline environment variables ─────────────────────────────
# Copy this file to .env and fill in values as needed.
# The pipeline works out-of-the-box with public NOAA data — no keys required.

# Optional: override default data/raw directory
# ENSO_RAW_DIR=data/raw

# Optional: override processed output path
# ENSO_PROCESSED_PATH=data/processed/enso_dataset.parquet

# Optional: set logging level (DEBUG | INFO | WARNING | ERROR)
# LOG_LEVEL=INFO

# Optional: Weights & Biases experiment tracking (not required)
# WANDB_API_KEY=your_key_here
# WANDB_PROJECT=enso-forecast
